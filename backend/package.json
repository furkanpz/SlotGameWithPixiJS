{
  "name": "backend",
  "version": "1.0.0",
  "main": "./out/src/server.js",
  "scripts": {
    "dev": "ts-node ./src/server.ts",
    "build": "tsc -p tsconfig.json",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node18 --external:aws-sdk --outfile=dist/lambda.js",
    "package:lambda": "npm run build:lambda && cd dist && zip -r lambda.zip lambda.js",
    "clean": "node -e \"const { rmSync } = require('node:fs'); ['out', 'dist'].forEach((dir) => rmSync(dir, { force: true, recursive: true }));\"",
    "start": "node ./out/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vendia/serverless-express": "^4.12.6",
    "aws-lambda": "^1.0.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.19.9",
    "esbuild": "^0.25.9",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "author": "",
  "license": "ISC",
  "description": "Local exhibition backend for the Lair of Riches slot demo"
}
