    "test": "npm run smoke",
    "clean": "node ./scripts/clean.mjs"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "dependencies": {
    "@pixi/basis": "^7.4.3",
    "@pixi/filter-drop-shadow": "^5.2.0",
    "gsap": "^3.13.0",
    "howler": "^2.2.4",
    "pixi.js": "^8.11.0",
    "stats.js": "^0.17.0"
  }
